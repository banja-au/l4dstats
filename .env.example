# Local-only defaults. Never commit downloaded demos or player data.
DATABASE_URL=file:./data/l4dstats.db
ARTIFACT_ROOT=./artifacts
INGEST_ALLOWED_HOSTS=cedapug.com
MAX_DOWNLOAD_BYTES=536870912
MAX_UNPACKED_BYTES=1073741824

# Local processing with hosted result publication. Never expose these to a browser.
L4DSTATS_BACKFILL_DB=./data/backfill/state.sqlite
L4DSTATS_BACKFILL_OBJECT_ROOT=./data/backfill/objects
L4DSTATS_DERIVED_BUCKET=l4dstats-staging-artifacts
L4DSTATS_PUBLIC_BASE_URL=https://staging.example.com
L4DSTATS_PSEUDONYM_KEY=
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
CLOUDFLARE_R2_S3_API_ENDPOINT=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
