{
  "name": "@l4dstats/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node ../../scripts/build-parser-sandbox.mjs && tsc -p tsconfig.json --noEmit false --outDir dist",
    "check": "tsc -p tsconfig.json --pretty false",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "test": "node ../../scripts/build-parser-sandbox.mjs && vitest run"
  },
  "dependencies": {
    "@l4dstats/acquisition": "workspace:*",
    "@l4dstats/api": "workspace:*",
    "@l4dstats/storage": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "tsx": "4.21.0",
    "vitest": "3.2.6"
  }
}
