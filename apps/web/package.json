{
  "name": "@l4dstats/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build && node scripts/copy-map-geometry.mjs && node scripts/check-asset-budget.mjs",
    "check": "tsc -b --pretty false && pnpm check:i18n",
    "check:i18n": "node scripts/check-i18n-copy.mjs",
    "dev": "vite",
    "start": "node server.mjs",
    "test:e2e": "playwright test",
    "test:e2e:real": "playwright test --config playwright.real.config.ts",
    "test:e2e:production": "playwright test --config playwright.production.config.ts",
    "test:budget": "node scripts/check-asset-budget.mjs",
    "test": "vitest run src --passWithNoTests && node scripts/test-production-server.mjs"
  },
  "dependencies": {
    "@fontsource-variable/space-grotesk": "5.2.8",
    "@l4dstats/contracts": "workspace:*",
    "@l4dstats/l4d2-rating": "workspace:*",
    "lucide-react": "0.544.0",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react": "5.0.4",
    "terser": "5.49.0",
    "vite": "7.3.5",
    "vitest": "3.2.6"
  }
}
