{
  "name": "@witchwatch/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build && node scripts/check-asset-budget.mjs",
    "check": "tsc -b --pretty false",
    "dev": "vite",
    "test:e2e": "playwright test",
    "test:e2e:real": "playwright test --config playwright.real.config.ts",
    "test:budget": "node scripts/check-asset-budget.mjs",
    "test": "vitest run src --passWithNoTests"
  },
  "dependencies": {
    "@tailwindcss/vite": "4.1.14",
    "@witchwatch/contracts": "workspace:*",
    "lucide-react": "0.544.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "tailwindcss": "4.1.14"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react": "5.0.4",
    "vite": "7.1.9",
    "vitest": "3.2.4"
  }
}
