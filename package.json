{
  "name": "l4dstats",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.13.1",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "bash scripts/prepare-native-parser.sh && turbo run build",
    "check": "cargo clippy --workspace --all-targets -- -D warnings && turbo run check",
    "dev": "pnpm native:prepare && turbo run dev --filter=@l4dstats/web",
    "dev:container": "turbo run dev --filter=@l4dstats/web -- --host 0.0.0.0",
    "dev:docker": "node scripts/check-dev-environment.mjs && docker compose up --build --force-recreate --remove-orphans",
    "dev:docker:down": "docker compose down",
    "prod:docker": "docker compose -f compose.production.yaml up --build",
    "prod:docker:down": "docker compose -f compose.production.yaml down",
    "backup:docker": "bash scripts/backup-workbench.sh",
    "restore:docker": "bash scripts/restore-workbench.sh",
    "retention:docker": "bash scripts/retention-workbench.sh",
    "health:production": "node scripts/check-production-health.mjs",
    "metrics:production": "node scripts/check-production-metrics.mjs",
    "measure:hosted": "node scripts/measure-hosted-footprint.mjs",
    "posthog:dashboard": "node scripts/provision-posthog-dashboard.mjs",
    "test:production": "pnpm build && node scripts/check-production-compose.mjs && node scripts/test-production-probes.mjs && node scripts/test-compiled-stack.mjs && node --conditions=production scripts/test-parser-sandbox.mjs",
    "test:sandbox": "pnpm --filter @l4dstats/worker build && pnpm --filter @l4dstats/cli build && node --conditions=production scripts/test-parser-sandbox.mjs",
    "test:recovery": "pnpm --filter @l4dstats/storage build && node scripts/test-backup-restore.mjs",
    "dev:cli": "pnpm native:prepare && pnpm --filter @l4dstats/cli dev",
    "maps:install": "docker compose --profile maps run --rm maps-install",
    "maps:extract": "docker compose --profile maps run --rm maps-extract",
    "maps:export": "bash ./scripts/export-map-geometry.sh",
    "reference:untitled:docker": "docker compose --profile tools run --rm reference",
    "scoring:evaluate": "pnpm --filter @l4dstats/cli dev calibrate ../../packages/scoring/fixtures/controlled-v1.json ../../packages/scoring/models",
    "security:check": "pnpm audit && pnpm licenses list --json | node scripts/check-licenses.mjs && cargo deny check",
    "test:e2e": "pnpm --filter @l4dstats/web test:e2e && pnpm --filter @l4dstats/web test:e2e:real",
    "format": "cargo fmt --all && prettier --write .",
    "format:check": "cargo fmt --all -- --check && prettier --check .",
    "test": "cargo test --workspace && bash scripts/prepare-native-parser.sh && node crates/demo-source1-node/test/load.test.mjs && turbo run test --concurrency=2",
    "native:bench": "cargo bench -p demo-source1-native",
    "native:prepare": "bash scripts/prepare-native-parser.sh",
    "native:stage": "cargo run -p demo-source1-native --release --bin demo-source1-stage --",
    "test:dev-startup": "node scripts/check-dev-native-startup.mjs"
  },
  "devDependencies": {
    "prettier": "3.6.2",
    "turbo": "2.10.5",
    "typescript": "5.9.3"
  }
}
