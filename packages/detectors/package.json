{
  "name": "@l4dstats/detectors",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "production": "./dist/index.js",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "benchmark": "vitest bench --run",
    "build": "tsc -p tsconfig.json --noEmit false --outDir dist",
    "check": "tsc -p tsconfig.json --pretty false",
    "test": "vitest run --maxWorkers=1",
    "test:real": "L4DSTATS_REAL_CORPUS=1 vitest run src/real-evidence.test.ts --pool=forks --maxWorkers=1"
  },
  "dependencies": {
    "@l4dstats/contracts": "workspace:*"
  },
  "devDependencies": {
    "vitest": "3.2.6"
  }
}
